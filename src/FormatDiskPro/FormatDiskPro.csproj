<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Nullable>enable</Nullable>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <DefineConstants>DISABLE_XAML_GENERATED_MAIN</DefineConstants>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>FormatDiskPro.ico</ApplicationIcon>
    <Version>1.2.2</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.*" />
  </ItemGroup>

  <ItemGroup>
    <None Update="FormatDiskPro.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!--
    Workaround: `dotnet publish` para apps WinUI 3 *unpackaged* (self-contained) NO copia
    el PRI propio de la app (<AssemblyName>.pri) a la carpeta de publicaciÃƒÂ³n; solo van los
    PRI del framework (Microsoft.UI.*.pri). Sin ese PRI, WinUI no puede resolver el XAML ni
    XamlControlsResources y la app CRASHEA al iniciar. Lo copiamos explÃƒÂ­citamente tras Publish.
  -->
  <Target Name="CopyAppPriToPublish" AfterTargets="Publish"
          Condition="Exists('$(TargetDir)$(TargetName).pri')">
    <Copy SourceFiles="$(TargetDir)$(TargetName).pri"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="false" />
    <Message Importance="high" Text="==> Copiado $(TargetName).pri al publish (recurso requerido por WinUI 3)." />
  </Target>

</Project>