<ContentDialog
    x:Class="FormatDiskPro.UI.LegalTextDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="8">

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <ScrollViewer MinWidth="360" MaxWidth="420" MaxHeight="420"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <TextBlock x:Name="BodyText" TextWrapping="Wrap" FontSize="12"
                   FontFamily="Consolas" IsTextSelectionEnabled="True" />
    </ScrollViewer>
</ContentDialog>
