<ContentDialog
    x:Class="FormatDiskPro.UI.HistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:FormatDiskPro.UI"
    CornerRadius="8">

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <Grid MinWidth="300" MaxWidth="420" RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <StackPanel Grid.Row="0" Spacing="8">
            <TextBox x:Name="SearchBox" PlaceholderText="Buscar…" TextChanged="Search_Changed" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <ComboBox x:Name="CategoryFilter" Grid.Column="0" HorizontalAlignment="Stretch"
                          SelectionChanged="Filter_Changed" />
                <ComboBox x:Name="ResultFilter" Grid.Column="1" HorizontalAlignment="Stretch"
                          SelectionChanged="Filter_Changed" />
            </Grid>
        </StackPanel>

        <ListView x:Name="EntriesList" Grid.Row="1" MaxHeight="320" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="ui:HistoryRow">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="0,4">
                        <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" Foreground="{x:Bind Accent}"
                                  FontSize="16" VerticalAlignment="Top" Margin="0,2,0,0" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{x:Bind Accent}" />
                                <TextBlock Text="{x:Bind Time}" FontSize="12" Opacity="0.6"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind Detail}" FontSize="12" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="EmptyText" Grid.Row="1" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Opacity="0.6" Visibility="Collapsed"
                   Text="Sin operaciones registradas." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button x:Name="OpenFileButton" Content="Abrir archivo" Click="OpenFile_Click" />
            <Button x:Name="ExportButton" Content="Exportar CSV" Click="Export_Click" />
            <Button x:Name="ClearButton" Content="Vaciar historial">
                <Button.Flyout>
                    <Flyout x:Name="ClearFlyout">
                        <StackPanel Spacing="10" MinWidth="200">
                            <TextBlock x:Name="ClearConfirmText" TextWrapping="Wrap"
                                       Text="¿Vaciar el historial?" />
                            <Button x:Name="ClearConfirmButton" Content="Vaciar"
                                    HorizontalAlignment="Right" Click="ClearConfirm_Click" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

    </Grid>
</ContentDialog>
