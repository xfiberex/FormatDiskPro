<ContentDialog
    x:Class="FormatDiskPro.UI.PresetsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fdp="using:FormatDiskPro"
    CornerRadius="8">

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <StackPanel MaxWidth="380" Spacing="12">

        <!-- Guardar configuración actual -->
        <StackPanel Spacing="6">
            <TextBlock x:Name="SaveHeader" FontWeight="SemiBold" />
            <TextBlock x:Name="CurrentText" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
            <TextBox x:Name="NameBox" MaxLength="40" />
            <TextBlock x:Name="ErrorText" FontSize="12" TextWrapping="Wrap" Visibility="Collapsed"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            <Button x:Name="SaveBtn" HorizontalAlignment="Right" CornerRadius="4" Click="SaveBtn_Click" />
        </StackPanel>

        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Presets propios -->
        <StackPanel Spacing="6">
            <TextBlock x:Name="ListHeader" FontWeight="SemiBold" />
            <TextBlock x:Name="EmptyText" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
            <ListView x:Name="PresetsList" MaxHeight="200" SelectionMode="None"
                      Padding="0" Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="fdp:FormatPreset">
                        <Grid ColumnDefinitions="*,Auto" MinHeight="36">
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="1" Tag="{x:Bind}" Click="DeleteBtn_Click"
                                    Background="Transparent" BorderThickness="0" Padding="6" CornerRadius="4">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </StackPanel>
</ContentDialog>
