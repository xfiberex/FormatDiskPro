<ContentDialog
    x:Class="FormatDiskPro.UI.PresetsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fdp="using:FormatDiskPro"
    CornerRadius="8">

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <StackPanel MaxWidth="380" Spacing="12">

        <!-- Guardar / editar configuración -->
        <StackPanel Spacing="6">
            <TextBlock x:Name="SaveHeader" FontWeight="SemiBold" />
            <TextBlock x:Name="CurrentText" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
            <TextBox x:Name="NameBox" MaxLength="40" />
            <CheckBox x:Name="UpdateConfigCheck" Visibility="Collapsed" />
            <TextBlock x:Name="ErrorText" FontSize="12" TextWrapping="Wrap" Visibility="Collapsed"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CancelEditBtn" CornerRadius="4" Visibility="Collapsed" Click="CancelEdit_Click" />
                <Button x:Name="SaveBtn" CornerRadius="4" Click="SaveBtn_Click" />
            </StackPanel>
        </StackPanel>

        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Presets propios -->
        <StackPanel Spacing="6">
            <TextBlock x:Name="ListHeader" FontWeight="SemiBold" />
            <TextBlock x:Name="EmptyText" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
            <ListView x:Name="PresetsList" MaxHeight="200" SelectionMode="None"
                      Padding="0" Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="fdp:FormatPreset">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" MinHeight="36">
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <Button x:Name="MoveUpBtn" Grid.Column="1" Tag="{x:Bind}" Click="MoveUp_Click" Loaded="IconBtn_Loaded"
                                    Background="Transparent" BorderThickness="0" Padding="6" CornerRadius="4">
                                <FontIcon Glyph="&#xE70E;" FontSize="14" />
                            </Button>
                            <Button x:Name="MoveDownBtn" Grid.Column="2" Tag="{x:Bind}" Click="MoveDown_Click" Loaded="IconBtn_Loaded"
                                    Background="Transparent" BorderThickness="0" Padding="6" CornerRadius="4">
                                <FontIcon Glyph="&#xE70D;" FontSize="14" />
                            </Button>
                            <Button x:Name="EditPresetBtn" Grid.Column="3" Tag="{x:Bind}" Click="EditBtn_Click" Loaded="IconBtn_Loaded"
                                    Background="Transparent" BorderThickness="0" Padding="6" CornerRadius="4">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" />
                            </Button>
                            <Button x:Name="DeletePresetBtn" Grid.Column="4" Tag="{x:Bind}" Click="DeleteBtn_Click" Loaded="IconBtn_Loaded"
                                    Background="Transparent" BorderThickness="0" Padding="6" CornerRadius="4">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </StackPanel>
</ContentDialog>
