<ContentDialog
    x:Class="FormatDiskPro.UI.ConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="8">

    <ContentDialog.PrimaryButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </ContentDialog.PrimaryButtonStyle>
    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </ContentDialog.CloseButtonStyle>

    <StackPanel Spacing="12" MinWidth="360" MaxWidth="420">
        <ScrollViewer MaxHeight="180">
            <TextBlock x:Name="SummaryText" TextWrapping="Wrap" FontSize="12.5"
                       FontFamily="Consolas" Margin="2,0" />
        </ScrollViewer>
        <TextBlock x:Name="PromptText" FontWeight="SemiBold" TextWrapping="Wrap"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
        <TextBox x:Name="InputBox" MaxLength="1" HorizontalAlignment="Stretch"
                 PlaceholderText="…" />
    </StackPanel>

</ContentDialog>
