<ContentDialog
    x:Class="FormatDiskPro.UI.WhatsNewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="8">

    <ContentDialog.PrimaryButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.PrimaryButtonStyle>
    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <StackPanel Width="380" Spacing="10">
        <TextBlock x:Name="VersionText" FontWeight="SemiBold"
                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="NotesText" TextWrapping="Wrap" FontSize="13" />
        </ScrollViewer>
    </StackPanel>
</ContentDialog>
