<ContentDialog
    x:Class="FormatDiskPro.UI.HealthDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="8">

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>
    <ContentDialog.SecondaryButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.SecondaryButtonStyle>

    <StackPanel MaxWidth="360" Spacing="10">
        <TextBlock x:Name="StatusText" FontSize="13" Opacity="0.7" />
        <StackPanel x:Name="RowsPanel" Spacing="6" />
        <TextBlock x:Name="NoteText" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
