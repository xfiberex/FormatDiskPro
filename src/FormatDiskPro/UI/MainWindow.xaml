<Window
    x:Class="FormatDiskPro.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:FormatDiskPro.UI"
    Title="FormatDiskPro">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Custom title bar drag area -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                       Text="FormatDiskPro" FontSize="12" />
        </Grid>

        <!-- Row 1: MenuBar -->
        <MenuBar Grid.Row="1">
            <MenuBarItem x:Name="MnuTools" Title="Herramientas">
                <MenuFlyoutItem x:Name="MnuVerify" Text="Verificar capacidad real…" Click="MnuVerify_Click" />
                <MenuFlyoutItem x:Name="MnuEject"  Text="Expulsar unidad"           Click="MnuEject_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MnuHistory" Text="Ver historial"            Click="MnuHistory_Click" />
            </MenuBarItem>
            <MenuBarItem x:Name="MnuConfig" Title="Configuración">
                <MenuFlyoutSubItem x:Name="MnuLang" Text="Idioma">
                    <ToggleMenuFlyoutItem x:Name="MnuLangEs" Text="Español"  IsChecked="True" Click="MnuLangEs_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuLangEn" Text="English"               Click="MnuLangEn_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem x:Name="MnuTheme" Text="Tema">
                    <ToggleMenuFlyoutItem x:Name="MnuThemeAuto"  Text="Automático" IsChecked="True" Click="MnuThemeAuto_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuThemeLight" Text="Claro"                       Click="MnuThemeLight_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuThemeDark"  Text="Oscuro"                      Click="MnuThemeDark_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem x:Name="MnuPresets" Text="Presets" />
            </MenuBarItem>
            <MenuBarItem x:Name="MnuHelp" Title="Ayuda">
                <MenuFlyoutItem x:Name="MnuUpdates" Text="Buscar actualizaciones…" Click="MnuUpdates_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MnuAbout" Text="Acerca de…" Click="MnuAbout_Click" />
            </MenuBarItem>
        </MenuBar>

        <!-- Row 2: Scrollable content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="16,12,16,0" Spacing="6">

                <!-- Drive selection -->
                <TextBlock x:Name="DriveLbl" Text="Unidad:" Margin="0,0,0,2" />
                <Grid ColumnDefinitions="*,Auto">
                    <ComboBox x:Name="DrivePicker" HorizontalAlignment="Stretch"
                              SelectionChanged="DrivePicker_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="ui:DriveViewModel">
                                <TextBlock Text="{x:Bind DisplayText}"
                                           Foreground="{x:Bind ForegroundBrush, Mode=OneWay}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button x:Name="RefreshButton" Grid.Column="1" Content="↻"
                            Margin="6,0,0,0" Padding="10,5" Click="RefreshButton_Click">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Name="RefreshTooltip" Content="Actualizar lista" />
                        </ToolTipService.ToolTip>
                    </Button>
                </Grid>

                <!-- Drive info panel -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12,10" Margin="0,4,0,0">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock x:Name="InfoTotalText"  Grid.Row="0" Grid.Column="0" FontSize="13" Text="Total: –" />
                        <TextBlock x:Name="InfoFsText"     Grid.Row="0" Grid.Column="1" FontSize="13" Text="Sistema actual: –" />
                        <TextBlock x:Name="InfoFreeText"   Grid.Row="1" Grid.Column="0" FontSize="13" Text="Libre: –"    Margin="0,4,0,0" />
                        <TextBlock x:Name="InfoTypeText"   Grid.Row="1" Grid.Column="1" FontSize="13" Text="Tipo: –"     Margin="0,4,0,0" />
                        <TextBlock x:Name="InfoHealthText" Grid.Row="2" Grid.Column="0" FontSize="13" Text="Salud: –"   Margin="0,4,0,0" />
                        <TextBlock x:Name="InfoBusText"    Grid.Row="2" Grid.Column="1" FontSize="13" Text="Conexión: –" Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <!-- File system -->
                <TextBlock x:Name="FileSystemLbl" Text="Sistema de archivos" Margin="0,8,0,2" />
                <ComboBox x:Name="FileSystemPicker" HorizontalAlignment="Stretch"
                          SelectionChanged="FileSystemPicker_SelectionChanged" />
                <TextBlock x:Name="FsDescText" FontSize="12" FontStyle="Italic"
                           Opacity="0.6" TextWrapping="Wrap" Margin="2,0,0,2" />

                <!-- Allocation unit -->
                <TextBlock x:Name="AllocUnitLbl" Text="Tamaño de unidad de asignación" Margin="0,4,0,2" />
                <ComboBox x:Name="AllocUnitPicker" HorizontalAlignment="Stretch" />
                <Button x:Name="RestoreButton" Content="Restaurar valores predeterminados"
                        HorizontalAlignment="Stretch" Margin="0,4,0,0"
                        Click="RestoreButton_Click" />

                <!-- Volume label -->
                <TextBlock x:Name="VolumeLabelLbl" Text="Etiqueta del volumen:" Margin="0,8,0,2" />
                <TextBox x:Name="VolumeLabelBox" MaxLength="32" HorizontalAlignment="Stretch" />

                <!-- Format options -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12,10" Margin="0,8,0,12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="OptionsGroupLbl" Text="Opciones de formato"
                                   FontWeight="SemiBold" Margin="0,0,0,2" />
                        <CheckBox x:Name="QuickFormatCheck" Content="Formato rápido"                        IsChecked="True" />
                        <CheckBox x:Name="CompressCheck"    Content="Habilitar compresión (sólo NTFS)"      IsEnabled="False" />
                        <CheckBox x:Name="SecureWipeCheck"  Content="Borrado seguro (sobrescribir espacio libre)" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 3: Progress bar -->
        <ProgressBar x:Name="FormatProgress" Grid.Row="3" Margin="16,6,16,2" />

        <!-- Row 4: Status + elapsed -->
        <Grid Grid.Row="4" Margin="16,0,16,6">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextWrapping="NoWrap" FontSize="12.5" />
            <TextBlock x:Name="ElapsedText" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Opacity="0.55" FontSize="12" />
        </Grid>

        <!-- Row 5: Action buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center"
                    Spacing="10" Margin="16,0,16,14">
            <Button x:Name="StartButton" Content="Iniciar" Width="110"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="StartButton_Click" />
            <Button x:Name="CloseButton" Content="Cerrar" Width="110"
                    Click="CloseButton_Click" />
        </StackPanel>

    </Grid>
</Window>
