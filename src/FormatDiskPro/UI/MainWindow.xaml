<Window
    x:Class="FormatDiskPro.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:FormatDiskPro.UI"
    Title="FormatDiskPro">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Custom title bar drag area (caption buttons themed automatically by WinUI) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="14,0,0,0" Spacing="12">
                <Image x:Name="TitleBarIcon" Width="16" Height="16" />
                <TextBlock Text="FormatDiskPro" VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <!-- Row 1: MenuBar -->
        <MenuBar Grid.Row="1">
            <MenuBarItem x:Name="MnuTools" Title="Herramientas">
                <MenuFlyoutItem x:Name="MnuVerify" Text="Verificar capacidad real…" Click="MnuVerify_Click" />
                <MenuFlyoutItem x:Name="MnuHealth" Text="Salud del disco (S.M.A.R.T.)…" Click="MnuHealth_Click" />
                <MenuFlyoutItem x:Name="MnuCheck"  Text="Comprobar errores (chkdsk)…" Click="MnuCheck_Click" />
                <MenuFlyoutItem x:Name="MnuBenchmark" Text="Benchmark rápido (lectura/escritura)…" Click="MnuBenchmark_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MnuUnlock" Text="Quitar protección de escritura…" Click="MnuUnlock_Click" />
                <MenuFlyoutItem x:Name="MnuReinit" Text="Reinicializar unidad…"     Click="MnuReinit_Click" />
                <MenuFlyoutItem x:Name="MnuEject"  Text="Expulsar unidad"           Click="MnuEject_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MnuHistory" Text="Ver historial"            Click="MnuHistory_Click" />
            </MenuBarItem>
            <MenuBarItem x:Name="MnuConfig" Title="Configuración">
                <MenuFlyoutSubItem x:Name="MnuLang" Text="Idioma">
                    <ToggleMenuFlyoutItem x:Name="MnuLangEs" Text="Español"  IsChecked="True" Click="MnuLangEs_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuLangEn" Text="English"               Click="MnuLangEn_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuLangPt" Text="Português"             Click="MnuLangPt_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuLangFr" Text="Français"              Click="MnuLangFr_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuLangIt" Text="Italiano"              Click="MnuLangIt_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem x:Name="MnuTheme" Text="Tema">
                    <ToggleMenuFlyoutItem x:Name="MnuThemeAuto"  Text="Automático" IsChecked="True" Click="MnuThemeAuto_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuThemeLight" Text="Claro"                       Click="MnuThemeLight_Click" />
                    <ToggleMenuFlyoutItem x:Name="MnuThemeDark"  Text="Oscuro"                      Click="MnuThemeDark_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem x:Name="MnuPresets" Text="Presets" />
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="MnuNotify" Text="Avisar al terminar" Click="MnuNotify_Click" />
            </MenuBarItem>
            <MenuBarItem x:Name="MnuHelp" Title="Ayuda">
                <MenuFlyoutItem x:Name="MnuUpdates" Text="Buscar actualizaciones…" Click="MnuUpdates_Click" />
                <MenuFlyoutItem x:Name="MnuWhatsNew" Text="Novedades…" Click="MnuWhatsNew_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MnuLicense" Text="Licencia…" Click="MnuLicense_Click" />
                <MenuFlyoutItem x:Name="MnuThirdParty" Text="Avisos de terceros…" Click="MnuThirdParty_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MnuAbout" Text="Acerca de…" Click="MnuAbout_Click" />
            </MenuBarItem>
        </MenuBar>

        <!-- Row 2: Scrollable content — cards inspired by Win11Debloat sections -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Padding="16,14,16,16" Spacing="12">

                <!-- Aviso persistente: unidad de sistema protegida (formateo deshabilitado) -->
                <InfoBar x:Name="ProtectedBar" Severity="Warning" IsClosable="False" IsOpen="False" />

                <!-- ── Card: Unidad (selección + información) ── -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEDA2;" Style="{StaticResource SectionIconStyle}" />
                            <TextBlock x:Name="UnitGroupLbl" Text="Unidad" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <Grid ColumnSpacing="8" ColumnDefinitions="*,Auto">
                            <ComboBox x:Name="DrivePicker" HorizontalAlignment="Stretch"
                                      SelectionChanged="DrivePicker_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="ui:DriveViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="14" VerticalAlignment="Center"
                                                      Foreground="{x:Bind ForegroundBrush, Mode=OneWay}" />
                                            <TextBlock Text="{x:Bind DisplayText}" VerticalAlignment="Center"
                                                       Foreground="{x:Bind ForegroundBrush, Mode=OneWay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button x:Name="RefreshButton" Grid.Column="1" VerticalAlignment="Stretch"
                                    Width="40" Padding="0" Click="RefreshButton_Click">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="F5" />
                                </Button.KeyboardAccelerators>
                                <FontIcon Glyph="&#xE72C;" FontSize="16" />
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Name="RefreshTooltip" Content="Actualizar lista" />
                                </ToolTipService.ToolTip>
                            </Button>
                        </Grid>

                        <Border Style="{StaticResource CardDividerStyle}" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="12" RowSpacing="6">
                            <TextBlock x:Name="InfoTotalText"  Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoTextStyle}" Text="Total: –" />
                            <TextBlock x:Name="InfoFsText"     Grid.Row="0" Grid.Column="1" Style="{StaticResource InfoTextStyle}" Text="Sistema actual: –" />
                            <TextBlock x:Name="InfoFreeText"   Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoTextStyle}" Text="Libre: –" />
                            <TextBlock x:Name="InfoTypeText"   Grid.Row="1" Grid.Column="1" Style="{StaticResource InfoTextStyle}" Text="Tipo: –" />
                            <TextBlock x:Name="InfoHealthText" Grid.Row="2" Grid.Column="0" Style="{StaticResource InfoTextStyle}" Text="Salud: –" />
                            <TextBlock x:Name="InfoBusText"    Grid.Row="2" Grid.Column="1" Style="{StaticResource InfoTextStyle}" Text="Conexión: –" />
                        </Grid>

                        <!-- Ocupación usado/libre de un vistazo (oculta si la unidad no está lista) -->
                        <ProgressBar x:Name="CapacityBar" Maximum="100" Margin="0,2,0,0"
                                     Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- ── Card: Configuración de formato ── -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" Style="{StaticResource SectionIconStyle}" />
                            <TextBlock x:Name="FormatGroupLbl" Text="Configuración de formato" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <ComboBox x:Name="FileSystemPicker" HorizontalAlignment="Stretch"
                                  Header="Sistema de archivos"
                                  SelectionChanged="FileSystemPicker_SelectionChanged" />
                        <TextBlock x:Name="FsDescText" Style="{StaticResource HintTextStyle}" Margin="2,0,0,0" />

                        <ComboBox x:Name="AllocUnitPicker" HorizontalAlignment="Stretch"
                                  Header="Tamaño de unidad de asignación" Margin="0,2,0,0" />

                        <TextBox x:Name="VolumeLabelBox" MaxLength="32" HorizontalAlignment="Stretch"
                                 Header="Etiqueta del volumen:" Margin="0,2,0,0"
                                 TextChanged="VolumeLabelBox_TextChanged" />
                        <TextBlock x:Name="LabelErrorText" FontSize="12" TextWrapping="Wrap"
                                   Margin="2,-4,0,0" Visibility="Collapsed"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" />

                        <Button x:Name="RestoreButton" Content="Restaurar valores predeterminados"
                                HorizontalAlignment="Stretch" Margin="0,2,0,0"
                                Click="RestoreButton_Click" />
                    </StackPanel>
                </Border>

                <!-- ── Card: Opciones de formato ── -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" Style="{StaticResource SectionIconStyle}" />
                            <TextBlock x:Name="OptionsGroupLbl" Text="Opciones de formato" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>
                        <CheckBox x:Name="QuickFormatCheck" Content="Formato rápido"                        IsChecked="True" />
                        <CheckBox x:Name="CompressCheck"    Content="Habilitar compresión (sólo NTFS)"      IsEnabled="False" />
                        <CheckBox x:Name="SecureWipeCheck"  Content="Borrado seguro (sobrescribir espacio libre)"
                                  Checked="SecureWipeCheck_Toggled" Unchecked="SecureWipeCheck_Toggled" />
                        <StackPanel x:Name="WipePassesPanel" Orientation="Horizontal" Spacing="8"
                                    Margin="30,0,0,0" VerticalAlignment="Center" Opacity="0.5">
                            <TextBlock x:Name="WipePassesLbl" Text="Pasadas:" VerticalAlignment="Center"
                                       Style="{StaticResource HintTextStyle}" />
                            <ComboBox x:Name="WipePassesPicker" MinWidth="64" IsEnabled="False"
                                      SelectionChanged="WipePassesPicker_SelectionChanged">
                                <ComboBoxItem Content="1" />
                                <ComboBoxItem Content="3" />
                                <ComboBoxItem Content="7" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 3: Footer action bar (progress + status + actions), Win11Debloat-style -->
        <Border Grid.Row="3" Style="{StaticResource FooterBarStyle}">
            <StackPanel Spacing="8">
                <ProgressBar x:Name="FormatProgress" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" FontSize="12.5" />
                    <TextBlock x:Name="ElapsedText" Grid.Column="1" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Opacity="0.55" FontSize="12" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                    <Button x:Name="CloseButton" Content="Cerrar" MinWidth="110"
                            Click="CloseButton_Click" />
                    <Button x:Name="StartButton" Grid.Column="2" Content="Iniciar" MinWidth="130"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="StartButton_Click" />
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</Window>
