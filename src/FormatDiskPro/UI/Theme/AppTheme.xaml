<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Tokens de diseño centralizados — lenguaje visual inspirado en Win11Debloat
        (tarjetas con encabezado de sección + icono y título de acento, barra de
        acción inferior). Los colores derivan de recursos Fluent que SIGUEN el color
        de acento que el usuario elige en Windows 11 (AccentTextFillColorPrimaryBrush)
        y se adaptan automáticamente a claro/oscuro. No hay colores hardcodeados.
    -->

    <!-- Radio de esquina de las tarjetas de sección -->
    <CornerRadius x:Key="AppCardCornerRadius">8</CornerRadius>

    <!-- Contenedor de sección: superficie sutil + borde de 1px (look "card" de Win11Debloat) -->
    <Style x:Key="AppCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <!-- Icono del encabezado de sección: tintado con el color de acento de Windows -->
    <Style x:Key="SectionIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Título del encabezado de sección: color de acento + semibold (estilo Win11Debloat) -->
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Texto de datos dentro de la tarjeta de unidad (etiqueta + valor, atenuado) -->
    <Style x:Key="InfoTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Descripción del sistema de archivos: pista atenuada y cursiva -->
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Separador fino dentro de una tarjeta -->
    <Style x:Key="CardDividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Barra de acción inferior (footer) separada del contenido con una línea superior -->
    <Style x:Key="FooterBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="16,10,16,14" />
    </Style>

</ResourceDictionary>
